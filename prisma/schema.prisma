datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Category {
  id             String    @id @default(uuid())
  slug           String    @unique
  name           String
  description    String
  image          String
  seoTitle       String
  seoDescription String
  parentSlug     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Product {
  id             String    @id
  name           String
  brand          String
  categorySlug   String
  subcategorySlug String?
  price          Int
  originalPrice  Int?
  rating         Float
  image          String
  description    String
  features       String    // JSON string representing string[]
  pros           String    // JSON string representing string[]
  cons           String    // JSON string representing string[]
  specs          String    // JSON string representing Record<string, string>
  dealTag        String?
  score          Int       @default(80)
  featured       Boolean   @default(false)
  status         String    @default("active") // "active" | "archived"
  affiliateUrls  String    // JSON: [{ network, url, price, primary? }]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Comparison {
  id               String    @id @default(uuid())
  slug             String    @unique
  title            String
  productAId       String
  productBId       String
  introduction     String
  featureBreakdown String    // JSON string representing comparison items
  verdict          String
  seoTitle         String
  seoDescription   String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Article {
  id                  String    @id @default(uuid())
  slug                String    @unique
  type                String    // "best" | "review" | "comparison" | "deal" | "blog"
  title               String
  description         String
  categorySlug        String
  date                String
  author              String
  image               String
  introduction        String
  quickRecommendation String?   // JSON
  topPicks            String?   // JSON
  productIds          String?   // JSON array of product IDs
  buyingGuide         String?   // JSON: [{ title, content }]
  faqs                String?   // JSON: [{ question, answer }]
  verdict             String?
  rating              Float?
  seoTitle            String
  seoDescription      String
  status              String    @default("published") // "published" | "draft"
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model Click {
  id               Int       @id @default(autoincrement())
  productId        String
  affiliateNetwork String
  affiliateUrl     String    @default("")
  clickedAt        DateTime  @default(now())
  ip               String?
  userAgent        String?
}

model Newsletter {
  id          Int      @id @default(autoincrement())
  email       String   @unique
  subscribedAt DateTime @default(now())
  active      Boolean  @default(true)
}
